{
  "name": "@keepass-web/kdbx",
  "version": "0.0.3",
  "type": "module",
  "description": "KDBX 3.1 and 4.x parser and serializer for keepass-web.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/keepass-web/kdbx.git"
  },
  "homepage": "https://github.com/keepass-web/kdbx#readme",
  "bugs": "https://github.com/keepass-web/kdbx/issues",
  "engines": {
    "node": ">=22.18.0"
  },
  "sideEffects": false,
  "exports": {
    ".": "./dist/src/index.js"
  },
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist",
    "src",
    "SPEC.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "node --experimental-strip-types --test 'tests/**/*.test.ts'"
  },
  "dependencies": {
    "@keepass-web/argon2": "^0.1.1",
    "@keepass-web/chacha20": "^0.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/node": "^22.20.0",
    "typescript": "6.0.3"
  }
}
